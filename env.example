# ============================================================
#  睿聘智模 v3.2  ·  .env.example  配置模板
#  使用方法：复制此文件为 .env，填入你的真实配置
#  命令：cp .env.example .env
# ============================================================

# ── LLM API 凭证（必填）────────────────────────────────────
API_BASE=https://api.rcouyi.com/v1
API_KEY=你的API密钥填在这里

# ── 模型配置（可选，有默认值）──────────────────────────────
# 主模型：评估 / 追问 / 报告 / 岗位分析
MODEL_NAME=gpt-4o
# 专用模型：仅用于生成面试题目（可单独升级到更强模型）
QUESTION_MODEL_NAME=gpt-5.4

# ── Web 服务（可选，有默认值）──────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
DEBUG_MODE=False
# 建议替换为随机长字符串，例如：openssl rand -hex 32
SECRET_KEY=your-random-secret-key-here

# ── 其他（可选）────────────────────────────────────────────
MAX_UPLOAD_MB=20
LLM_TIMEOUT=120
